<div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 mt-8">
  <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">Request Attendance</h2>

  <div class="mb-6 border-b dark:border-gray-700 pb-4">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2"><%= @property.title %></h3>
    <p class="text-gray-600 dark:text-gray-400 mb-1"><%= @property.address %></p>
    <p class="text-sm text-gray-500 dark:text-gray-300"><%= @property.start_time.strftime('%A, %B %d, %Y from %I:%M %p') %> - <%= @property.end_time.strftime('%I:%M %p') %></p>
  </div>

  <p class="text-gray-700 dark:text-gray-300 mb-6 text-sm">
    You are requesting to attend the open house for the property listed above. 
    Click the button below to submit your request. You will be notified once the realtor reviews your request.
    (In the future, you will be asked to upload identification here.)
  </p>

  <%= form_with(model: @signup, url: property_signups_path(@property), method: :post) do |form| %>
    <%# No fields needed yet, just the submit button %>
    <div>
      <%= form.submit "Confirm Request", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 dark:focus:ring-offset-gray-800 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to 'Cancel', property_path(@property), class: "text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 transition font-medium text-sm" %>
  </div>
</div>
