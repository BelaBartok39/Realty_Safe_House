<div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 mt-8">
  <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">Request Attendance</h2>

  <div class="mb-6 border-b dark:border-gray-700 pb-4">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2"><%= @property.title %></h3>
    <p class="text-gray-600 dark:text-gray-400 mb-1"><%= @property.address %></p>
    <p class="text-sm text-gray-500 dark:text-gray-300"><%= @property.start_time.strftime('%A, %B %d, %Y from %I:%M %p') %> - <%= @property.end_time.strftime('%I:%M %p') %></p>
  </div>

  <%# Updated form with file fields %>
  <%= form_with(model: [@property, @signup], local: true, class: "space-y-4") do |form| %>
    <% if @signup.errors.any? %>
      <div id="error_explanation" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
        <strong class="font-bold">Please fix the following errors:</strong>
        <ul class="mt-2 list-disc list-inside">
          <% @signup.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# --- License Front --- %>
    <div class="field">
      <%= form.label :license_front, class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
      <%= form.file_field :license_front, accept: "image/*", required: true, class: "block w-full text-sm text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 dark:text-gray-400 focus:outline-none dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400" %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Upload a clear picture of the front of your driver's license or ID.</p>
    </div>

    <%# --- License Back --- %>
    <div class="field">
      <%= form.label :license_back, class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
      <%= form.file_field :license_back, accept: "image/*", required: true, class: "block w-full text-sm text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 dark:text-gray-400 focus:outline-none dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400" %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Upload a clear picture of the back of your driver's license or ID.</p>
    </div>

    <%# --- Selfie --- %>
    <div class="field">
      <%= form.label :selfie, class: "block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1" %>
      <%= form.file_field :selfie, accept: "image/*", required: true, class: "block w-full text-sm text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 dark:text-gray-400 focus:outline-none dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400" %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Upload a clear, recent photo of your face (no hats or sunglasses).</p>
    </div>

    <div class="actions">
      <%= form.submit "Submit Request", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:focus:ring-offset-gray-800 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to 'Cancel', property_path(@property), class: "text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 transition font-medium text-sm" %>
  </div>
</div>
