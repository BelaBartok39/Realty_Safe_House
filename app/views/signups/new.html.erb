<div class="max-w-xl mx-auto bg-white p-6 rounded-xl shadow">
  <h1 class="text-xl font-bold mb-4 text-gray-800">Request to Attend Open House</h1>
  <%= form_with(model: @signup, local: true, html: { class: 'space-y-6' }) do |form| %>
    <div>
      <%= form.label :license_front, 'Upload License (Front)', class: 'block font-medium text-gray-700 mb-1' %>
      <%= form.file_field :license_front, class: 'w-full border-gray-300 rounded px-3 py-2' %>
    </div>
    <div>
      <%= form.label :license_back, 'Upload License (Back)', class: 'block font-medium text-gray-700 mb-1' %>
      <%= form.file_field :license_back, class: 'w-full border-gray-300 rounded px-3 py-2' %>
    </div>
    <div>
      <%= form.label :selfie, 'Upload Selfie (Optional)', class: 'block font-medium text-gray-700 mb-1' %>
      <%= form.file_field :selfie, class: 'w-full border-gray-300 rounded px-3 py-2' %>
    </div>
    <div>
      <%= form.submit 'Submit Request', class: 'w-full bg-blue-600 text-white font-semibold py-2 rounded hover:bg-blue-700 transition' %>
    </div>
  <% end %>
  <div class="mt-4">
    <%= link_to 'Back to Properties', properties_path, class: 'text-blue-600 hover:underline' %>
  </div>
</div>
