<div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 mt-8">
  <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">Signup Request Details</h2>

  <%# Display flash notice if redirected from create %>
  <% if notice %>
    <div class="bg-green-100 dark:bg-green-900/50 border border-green-300 dark:border-green-700 text-green-800 dark:text-green-200 px-4 py-3 rounded mb-6 shadow-sm transition-colors duration-300 text-sm">
      <%= notice %>
    </div>
  <% end %>

  <div class="mb-6 border-b dark:border-gray-700 pb-4">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2"><%= @signup.property.title %></h3>
    <p class="text-gray-600 dark:text-gray-400 mb-1"><%= @signup.property.address %></p>
    <p class="text-sm text-gray-500 dark:text-gray-300"><%= @signup.property.start_time.strftime('%A, %B %d, %Y from %I:%M %p') %> - <%= @signup.property.end_time.strftime('%I:%M %p') %></p>
  </div>

  <div class="space-y-4">
    <div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Requested By:</span>
      <span class="text-gray-900 dark:text-white ml-2"><%= @signup.user.email %></span>
    </div>
    <div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Request Status:</span>
      <span class="ml-2 px-2 py-0.5 rounded text-sm font-medium <%= status_badge_class(@signup.status) %>">
        <%= @signup.status.humanize %>
      </span>
    </div>
    <div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Requested At:</span>
      <span class="text-gray-900 dark:text-white ml-2"><%= @signup.created_at.strftime('%B %d, %Y %I:%M %p %Z') %></span>
    </div>

    <%# Placeholder for future ID uploads/viewing %>
    <% if @signup.pending? && current_user == @signup.user %>
      <div class="border-t dark:border-gray-700 pt-4 mt-4 text-sm text-gray-600 dark:text-gray-400">
        (Future step: Upload identification documents here)
      </div>
    <% end %>

    <%# Placeholder for Realtor actions %>
    <% if current_user.realtor? && current_user == @signup.property.realtor && @signup.pending? %>
       <div class="border-t dark:border-gray-700 pt-4 mt-4 flex gap-4">
         <%# TODO: Add Approve/Deny buttons %>
         <button class="bg-green-500 text-white px-4 py-1 rounded text-sm font-medium hover:bg-green-600 transition">Approve (Not Implemented)</button>
         <button class="bg-red-500 text-white px-4 py-1 rounded text-sm font-medium hover:bg-red-600 transition">Deny (Not Implemented)</button>
       </div>
    <% end %>

  </div>

  <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700 flex justify-between items-center">
    <%= link_to 'Back to Property', property_path(@signup.property), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition font-medium text-sm" %>
    <%# Link to 'My Requests' or 'Manage Signups' depending on role %>
    <%= link_to (current_user.client? ? 'My Requests' : 'Manage Signups'), signups_path, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition font-medium text-sm" %>
  </div>

</div>
