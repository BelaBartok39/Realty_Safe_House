<div class="max-w-xl mx-auto">
  <h1 class="text-2xl md:text-3xl font-bold mb-6 text-gray-800 dark:text-white">Edit Property</h1>
  <%= render 'form', property: @property %>

  <div class="mt-6 text-center">
    <%= link_to 'Back to Property', @property, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition" %> |
    <%= link_to 'Delete Property', @property, data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: "text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 transition" %>
  </div>
</div>
